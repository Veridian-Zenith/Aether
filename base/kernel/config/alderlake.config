# i3-1215U (Alder Lake) specific hardware support
# 2 P-cores + 4 E-cores, Intel Xe GPU, AX201 WiFi

# GPU — Intel Xe (DG2/Alchemist) and legacy i915
CONFIG_DRM=y
CONFIG_DRM_I915=y
CONFIG_DRM_XE=y
CONFIG_DRM_XE_FORCE_PROBE="46b3"

# CPU / Platform
CONFIG_X86_INTEL_IFS=y
CONFIG_X86_INTEL_TSX_MODE_OFF=y
CONFIG_X86_INTEL_TSX_DISABLE=y
CONFIG_CPU_SUP_INTEL=y
CONFIG_PROCESSOR_SELECT=y
CONFIG_GUP_TEST=n
CONFIG_MICROCODE_INTEL=y
CONFIG_MICROCODE_LATE_LOADING=n
CONFIG_X86_CPU_RESCTRL=y
CONFIG_INTEL_IOMMU=y
CONFIG_INTEL_IOMMU_DEFAULT_ON=y
CONFIG_INTEL_IOMMU_SVM=y
CONFIG_INTEL_IOMMU_FLOPPY_WA=n
CONFIG_IRQ_REMAP=y

# Intel HWP (Hardware P-State)
CONFIG_X86_INTEL_PSTATE=y
CONFIG_X86_ACPI_CPUFREQ=n

# Power management
CONFIG_INTEL_IDLE=y
CONFIG_INTEL_IDLE_S3_DISABLE=n
CONFIG_INTEL_PMIC=y
CONFIG_INTEL_PMC_CORE=y
CONFIG_INTEL_TURBO_MAX_3=y

# NVMe
CONFIG_BLK_DEV_NVME=y

# Audio — SOF for Alder Lake
CONFIG_SND_SOC_SOF_INTEL_SOUNDWIRE=n
CONFIG_SND_SOC_SOF_ALDERLAKE=y
CONFIG_SND_SOC_INTEL_AVS=n
CONFIG_SND_INTEL_DSP_CONFIG=y
CONFIG_SND_INTEL_SOF=y

# WiFi — Intel AX201
CONFIG_WLAN=y
CONFIG_IWLWIFI=y
CONFIG_IWLWIFI_LEDS=y
CONFIG_IWLDVM=n
CONFIG_IWLMVM=y
CONFIG_IWLMEI=n
CONFIG_BT_HCIBTUSB=y
CONFIG_BT_INTEL=y

# USB / Thunderbolt
CONFIG_USB4=y
CONFIG_USB_XHCI_HCD=y

# Virtualization
CONFIG_KVM=y
CONFIG_KVM_INTEL=y
