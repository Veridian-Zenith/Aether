# Aether base kernel config — security-hardened, minimal footprint
CONFIG_LOCALVERSION="-aether"
CONFIG_LOCALVERSION_AUTO=n

# Preemption: voluntary
CONFIG_PREEMPT_VOLUNTARY=y
CONFIG_PREEMPT=n
CONFIG_PREEMPT_NONE=n

# Scheduler
CONFIG_SCHED_EEVDF=y
CONFIG_SCHED_CLASS_EXT=y
CONFIG_SCX_LAVD=y

# Security
CONFIG_SECURITY=y
CONFIG_SECURITY_WRITABLE_HOOKS=n
CONFIG_SECURITY_LOCKDOWN_LSM=y
CONFIG_LOCKDOWN_KERNEL_FORCE_CONFIDENTIALITY=y
CONFIG_SECURITY_YAMA=y
CONFIG_SECURITY_LOADPIN=y
CONFIG_SECURITY_SAFESETID=y
CONFIG_STACKPROTECTOR_STRONG=y
CONFIG_SHADOW_STACK=y

# Hardening
CONFIG_BUG_ON_DATA_CORRUPTION=y
CONFIG_DEBUG_LIST=y
CONFIG_DEBUG_SG=y
CONFIG_DEBUG_CREDENTIALS=y
CONFIG_DEBUG_NOTIFIERS=y
CONFIG_SCHED_STACK_END_CHECK=y
CONFIG_INIT_ON_ALLOC_DEFAULT_ON=y
CONFIG_INIT_ON_FREE_DEFAULT_ON=y
CONFIG_SLAB_FREELIST_RANDOM=y
CONFIG_SLAB_FREELIST_HARDENED=y
CONFIG_RANDOMIZE_KSTACK_OFFSET=y

# LTO
CONFIG_LTO_CLANG_THIN=y
CONFIG_LTO_NONE=n
CONFIG_LTO_CLANG_FULL=n

# Firmware loading
CONFIG_FW_LOADER=y
CONFIG_FIRMWARE_IN_KERNEL=y
CONFIG_EXTRA_FIRMWARE_DIR="firmware"
CONFIG_EXTRA_FIRMWARE=""

# Modules
CONFIG_MODULES=y
CONFIG_MODULE_SIG=y
CONFIG_MODULE_SIG_ALL=y
CONFIG_MODULE_SIG_SHA512=y
CONFIG_MODULE_SIG_HASH="sha512"
CONFIG_MODULE_COMPRESS_ZSTD=y
CONFIG_TRIM_UNUSED_KSYMS=y
